# Neon Postgres connection string (copy from Neon dashboard → Connection details)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Password for the single user "adri"
ADRI_PASSWORD=changeme

# Iron-session cookie secret — generate with `openssl rand -base64 32` (must be ≥ 32 chars)
SESSION_PASSWORD=at-least-32-characters-long-random-string-please
